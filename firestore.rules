rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Admin Check: Need a way to check if a user is an admin. 
    // Per instructions: "Only look up roles using get() or exists() on a trusted database document."
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users {
      allow list: if isAdmin();
    }
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && (incoming().role == 'worker' || (incoming().email == 'mdv4244@gmail.com' && incoming().role == 'admin'));
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin()) && 
                    incoming().role == existing().role; // Cannot change own role
    }

    match /timeEntries/{entryId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /registrationCodes/{codeId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
